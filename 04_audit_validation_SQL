
-- 04_audit_validation.sql
-- Central validation log + all data quality checks.
-- Runs daily, LAST, after staging and mart are both built.


-- Central validation log
CREATE TABLE IF NOT EXISTS audit.validation_log (
    log_id           INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    layer            VARCHAR(50),
    table_name       VARCHAR(100),
    check_name       VARCHAR(100),
    records_checked  INTEGER,
    records_failed   INTEGER,
    severity         VARCHAR(20),     -- ERROR, WARNING, INFO
    notes            TEXT,
    checked_at       TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Clear only today's checks so reruns don't duplicate log rows
DELETE FROM audit.validation_log
WHERE checked_at::date = CURRENT_DATE;

