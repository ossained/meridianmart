-- Validation report: view all failures (run manually / for debugging)

SELECT
    layer,
    table_name,
    check_name,
    records_checked,
    records_failed,
    severity,
    notes,
    checked_at
FROM audit.validation_log
WHERE records_failed > 0
ORDER BY
    CASE severity WHEN 'ERROR' THEN 1 WHEN 'WARNING' THEN 2 ELSE 3 END,
    checked_at;